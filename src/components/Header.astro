---
import { SITE_TITLE, SOCIAL } from '../consts';
---

<header class="header">
  <div class="header-container">
    <a href="/" class="logo">
      <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" width="24" height="24">
        <style>
          .logo-wl { fill: none; stroke: #d4a574; stroke-width: 4; stroke-linecap: round; stroke-dasharray: 24; stroke-dashoffset: 24; }
          .logo-l1 { animation: logoLine1 3s ease-out infinite; }
          .logo-l2 { animation: logoLine2 3s ease-out infinite; stroke-dasharray: 16; stroke-dashoffset: 16; }
          @keyframes logoLine1 { 0%, 15% { stroke-dashoffset: 24; } 40%, 100% { stroke-dashoffset: 0; } }
          @keyframes logoLine2 { 0%, 45% { stroke-dashoffset: 16; } 70%, 100% { stroke-dashoffset: 0; } }
          .logo-quill { transform-origin: 40px 45px; animation: logoWrite 3s ease-in-out infinite; }
          @keyframes logoWrite { 0%, 15% { transform: translate(0,-18px) rotate(5deg); } 15%, 40% { transform: translate(0,-18px) rotate(-3deg); } 40%, 45% { transform: translate(0,-4px) rotate(5deg); } 45%, 70% { transform: translate(0,-4px) rotate(-3deg); } 70%, 100% { transform: translate(0,-18px) rotate(5deg); } }
        </style>
        <rect x="8" y="12" width="48" height="40" rx="4" stroke="#c4b8a8" stroke-width="4" fill="none"/>
        <line x1="32" y1="12" x2="32" y2="52" stroke="#c4b8a8" stroke-width="4"/>
        <line x1="16" y1="26" x2="40" y2="26" class="logo-wl logo-l1"/>
        <line x1="16" y1="40" x2="32" y2="40" class="logo-wl logo-l2"/>
        <g class="logo-quill">
          <path d="M40 45L36 34C36 34 46 12 58 6C54 20 44 34 44 34Z" fill="#d4a574"/>
          <polygon points="40,45 38,49 41,49" fill="#e8c496"/>
        </g>
      </svg>
      <span class="logo-name">{SITE_TITLE}</span>
    </a>
    
    <nav class="nav">
      <a href="/" class="nav-link">Home</a>
      <a href="/blog/" class="nav-link">Journal</a>
      <a href="/about/" class="nav-link">About</a>
      <a href="/games/retro-cruiser/index.html" class="nav-link nav-link-accent">
        Play Game
      </a>
    </nav>

    <div class="header-actions">
      <a href="/rss.xml" class="action-link" title="RSS Feed">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
          <path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36m12.9 4.36A15.08 15.08 0 0 0 4 4.92V8.1a11.9 11.9 0 0 1 11.9 11.9h3.18zM12.54 20A10.54 10.54 0 0 0 4 9.46v3.18a7.36 7.36 0 0 1 7.36 7.36h1.18z"/>
        </svg>
      </a>
      {SOCIAL.twitter && (
        <a href={SOCIAL.twitter} class="action-link" target="_blank" rel="noopener noreferrer" title="X (Personal)">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      )}
      {SOCIAL.twitterQA && (
        <a href={SOCIAL.twitterQA} class="action-link action-link-qa" target="_blank" rel="noopener noreferrer" title="Quant Alchemy on X">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      )}
      {SOCIAL.facebook && (
        <a href={SOCIAL.facebook} class="action-link" target="_blank" rel="noopener noreferrer" title="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(26, 22, 20, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: var(--border-subtle);
  }

  .header-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
  }

  .logo-icon {
    width: 24px;
    height: 24px;
    color: var(--accent-primary);
    transition: var(--transition-base);
  }

  .logo:hover .logo-icon {
    color: var(--accent-highlight);
  }

  .logo-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(212, 165, 116, 0.08);
  }

  .nav-link-accent {
    color: var(--accent-primary);
    border: 1px solid var(--accent-tertiary);
  }

  .nav-link-accent:hover {
    background: var(--accent-primary);
    color: var(--bg-primary);
    border-color: var(--accent-primary);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .action-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    color: var(--text-muted);
    border-radius: var(--radius-sm);
    transition: var(--transition-fast);
  }

  .action-link:hover {
    color: var(--accent-primary);
    background: rgba(212, 165, 116, 0.08);
  }

  @media (max-width: 640px) {
    .header-container {
      padding: 0.75rem 1rem;
    }

    .logo-name {
      display: none;
    }

    .nav-link {
      padding: 0.5rem 0.75rem;
      font-size: 0.85rem;
    }
  }
</style>
